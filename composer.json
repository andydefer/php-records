{
    "name": "andydefer/php-records",
    "abandoned": "andydefer/domain-structures",
    "description": "A typed data structure package that brings type safety to internal application communication in PHP.",
    "license": "MIT",
    "authors": [
        {
            "name": "Andy Kani",
            "email": "andykanidimbu@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.6",
        "composer/composer": "^2.0",
        "larastan/larastan": "^3.8",
        "laravel/pint": "^1.26",
        "orchestra/testbench": "^10.8",
        "phpunit/phpunit": "^12.5",
        "rector/rector": "*",
        "symfony/var-dumper": "^7.0",
        "vimeo/psalm": "^6.14"
    },
    "autoload": {
        "psr-4": {
            "AndyDefer\\Records\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AndyDefer\\Records\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "lint": "pint",
        "analyse": "phpstan analyse",
        "psalm": "psalm"
    }
}